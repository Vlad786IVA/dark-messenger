<Window x:Class="DARK_Messenger_WPF.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DARK Messenger — Регистрация"
        Width="460" Height="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">
    <Window.Resources>
        <DropShadowEffect x:Key="NeonGlow" Color="#2AABEE" BlurRadius="24" ShadowDepth="0" Opacity="0.6" />
        <DropShadowEffect x:Key="Shadow" Color="#000000" BlurRadius="30" ShadowDepth="4" Opacity="0.5" />
    </Window.Resources>

    <Border Effect="{StaticResource Shadow}" CornerRadius="16" Background="#0E1621">
        <Grid Margin="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="52" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Border Grid.Row="0" Background="#0A0E17" CornerRadius="16,16,0,0" Padding="16,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="DARK" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="Регистрация" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0" />
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="─" FontSize="14" Width="36" Height="28"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                Cursor="Hand" Click="Minimize_Click" />
                        <Button Content="✕" FontSize="14" Width="36" Height="28"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                Cursor="Hand" Click="Close_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- DRAG -->
            <Border Grid.Row="0" Background="Transparent" MouseLeftButtonDown="Border_MouseLeftButtonDown"
                    CornerRadius="16,16,0,0" />

            <!-- CONTENT -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="340" Margin="0,10,0,30">

                    <Border Width="72" Height="72" CornerRadius="20" Background="#202B36"
                            HorizontalAlignment="Center" Effect="{StaticResource NeonGlow}">
                        <TextBlock Text="D" FontSize="36" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Создание аккаунта" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"
                               HorizontalAlignment="Center" Margin="0,14,0,4" />
                    <TextBlock Text="Присоединяйтесь к DARK" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,6" />

                    <StackPanel Margin="0,16,0,0">
                        <TextBlock Text="Логин" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,0,0,6" />
                        <Border CornerRadius="12" Background="#1A2A40" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <TextBox x:Name="UsernameBox" Background="Transparent" BorderThickness="0"
                                     FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}"
                                     Padding="14,12" Tag="Введите логин" />
                        </Border>

                        <TextBlock Text="Отображаемое имя" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,14,0,6" />
                        <Border CornerRadius="12" Background="#1A2A40" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <TextBox x:Name="DisplayNameBox" Background="Transparent" BorderThickness="0"
                                     FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}"
                                     Padding="14,12" Tag="Ваше имя" />
                        </Border>

                        <TextBlock Text="Пароль" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,14,0,6" />
                        <Border CornerRadius="12" Background="#1A2A40" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <PasswordBox x:Name="PasswordBox" Background="Transparent" BorderThickness="0"
                                         FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}"
                                         Padding="14,12" />
                        </Border>

                        <Button x:Name="RegisterButton" Content="Зарегистрироваться"
                                Style="{StaticResource AccentButton}"
                                HorizontalAlignment="Stretch" Height="46" FontSize="15"
                                Margin="0,18,0,0" Click="Register_Click" />

                        <Button x:Name="BackToLoginButton" Content="Назад ко входу"
                                Style="{StaticResource LinkButton}"
                                HorizontalAlignment="Center" Margin="0,14,0,0"
                                FontSize="13" Click="BackToLogin_Click" />
                    </StackPanel>

                    <Border x:Name="StatusBorder" Background="#1A2A40" CornerRadius="10"
                            Padding="14,10" Margin="0,14,0,0" Visibility="Collapsed"
                            BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1">
                        <TextBlock x:Name="StatusText" Foreground="{DynamicResource AccentBrush}"
                                   FontSize="13" TextWrapping="Wrap" TextAlignment="Center" />
                    </Border>

                    <ProgressBar x:Name="LoadingBar" IsIndeterminate="True" Visibility="Collapsed"
                                 Margin="0,14,0,0" Foreground="{DynamicResource AccentBrush}"
                                 Height="3" Background="#1A2A40" />
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
