<Window x:Class="DARK_Messenger_WPF.Views.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Профиль" Width="360" Height="520"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="50" /><RowDefinition Height="*" /></Grid.RowDefinitions>
        <Border Grid.Row="0" Background="Transparent" MouseLeftButtonDown="Drag_MouseDown" Padding="16,0">
            <Grid>
                <TextBlock Text="Профиль" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource TextSecondaryBrush}" FontSize="18" Cursor="Hand" Click="Close_Click" Width="36" Height="36" />
            </Grid>
        </Border>
        <StackPanel Grid.Row="1" Margin="24,0,24,16" VerticalAlignment="Top">
            <Border x:Name="AvatarBorder" Width="80" Height="80" CornerRadius="40" Background="{DynamicResource PrimaryBrush}"
                    HorizontalAlignment="Center" Margin="0,8,0,16" Cursor="Hand" MouseLeftButtonDown="ChangeAvatar_Click">
                <TextBlock x:Name="AvatarText" Text="?" FontSize="32" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="Логин" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
            <TextBlock x:Name="UsernameText" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" Margin="0,0,0,12" />
            <TextBlock Text="Имя" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4" />
            <TextBox x:Name="DisplayNameBox" Style="{StaticResource DarkTextBox}" Margin="0,0,0,12" />
            <Button Content="Сохранить" Style="{StaticResource AccentButton}" HorizontalAlignment="Stretch" Click="Save_Click" Margin="0,0,0,12" />

            <Separator Background="{DynamicResource BorderBrush}" Margin="0,4,0,12" />

            <Button Content="🌗 Сменить тему" Style="{StaticResource LinkButton}" HorizontalAlignment="Stretch" Click="SwitchTheme_Click" Margin="0,0,0,4" />
            <Button Content="🌐 EN / RU" Style="{StaticResource LinkButton}" HorizontalAlignment="Stretch" Click="SwitchLang_Click" Margin="0,0,0,12" />

            <Separator Background="{DynamicResource BorderBrush}" Margin="0,4,0,12" />

            <Button Content="🚪 Выйти" Style="{StaticResource LinkButton}" HorizontalAlignment="Stretch" Foreground="#E94560" Click="Logout_Click" />
            <TextBlock x:Name="StatusText" Foreground="{DynamicResource AccentBrush}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,12,0,0" Visibility="Collapsed" />
        </StackPanel>
    </Grid>
</Window>
