<Window x:Class="DARK_Messenger_WPF.Views.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowState="Maximized"
        ShowInTaskbar="False"
        Topmost="True"
        KeyDown="Window_KeyDown"
        Cursor="Hand">
    <Grid>
        <Border Background="#CC000000" MouseLeftButtonDown="Close_Click" />
        <Image x:Name="ViewerImage" MaxWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}"
               MaxHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Window}}"
               Stretch="Uniform" Margin="40"
               Cursor="Arrow" />
        <Button Content="✕" FontSize="22" Foreground="White" Background="#44000000"
                BorderThickness="0" Cursor="Hand" Width="48" Height="48"
                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12,12,12,12"
                Click="Close_Click" />
    </Grid>
</Window>
