<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:DARK_Messenger.Views"
       x:Class="DARK_Messenger.AppShell"
       Shell.FlyoutBehavior="Disabled"
       BackgroundColor="#0E1621"
       Shell.TabBarBackgroundColor="#0E1621"
       Shell.TabBarForegroundColor="#2AABEE"
       Shell.TabBarUnselectedColor="#636366"
       Shell.BackgroundColor="#0E1621"
       Shell.ForegroundColor="White"
       Shell.TitleColor="White">

    <TabBar Route="auth" Shell.TabBarIsVisible="False">
        <ShellContent Route="login" ContentTemplate="{DataTemplate views:LoginPage}" />
        <ShellContent Route="register" ContentTemplate="{DataTemplate views:RegisterPage}" />
    </TabBar>

    <TabBar Route="main">
        <ShellContent Route="chatlist" Title="Чаты" ContentTemplate="{DataTemplate views:ChatListPage}" />
        <ShellContent Route="contacts" Title="Контакты" ContentTemplate="{DataTemplate views:ContactsPage}" />
    </TabBar>

</Shell>
