<Window x:Class="DARK_Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DARK Server Launcher" Width="480" Height="360"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        ResizeMode="CanMinimize"
        Closing="Window_Closing">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="DARK Messenger Server" FontSize="22" FontWeight="Bold"
                   Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,12" />

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Ellipse Grid.Column="0" x:Name="StatusDot" Width="14" Height="14" Fill="{StaticResource RedBrush}"
                     VerticalAlignment="Center" Margin="0,0,10,0" />
            <TextBlock Grid.Column="1" x:Name="StatusText" Text="Остановлен" FontSize="15"
                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
            <Button Grid.Column="2" x:Name="ToggleBtn" Content="▶ Старт" FontSize="14" FontWeight="SemiBold"
                    Width="110" Height="36" Cursor="Hand"
                    Background="{StaticResource AccentBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                    BorderThickness="0" Click="ToggleBtn_Click" />
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="6" Padding="12,8" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Локальный:" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                <TextBlock x:Name="LocalUrl" Text="http://localhost:8080" FontSize="13"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Сеть:" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" />
                <TextBlock x:Name="NetworkUrl" Text="—" FontSize="13"
                           Foreground="{StaticResource TextPrimaryBrush}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}" CornerRadius="6" Padding="8" Margin="0,0,0,10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="LogText" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                         FontFamily="Consolas" TextWrapping="Wrap" IsReadOnly="True"
                         Background="Transparent" BorderThickness="0"
                         CaretBrush="Transparent" />
            </ScrollViewer>
        </Border>

        <TextBlock Grid.Row="4" Text="DARK Messenger © 2026" FontSize="11"
                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
    </Grid>
</Window>
